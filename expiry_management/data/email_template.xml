<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <record id="email_template_product_expiry_alert" model="mail.template">
        <field name="name">Product Expiry Alert</field>
        <field name="model_id" ref="stock.model_stock_lot"/>
        <field name="subject">[Cảnh báo] Hàng sắp Hết hạn</field>
        <field name="email_from">{{ object.company_id.email or user.email }}</field>
        <field name="email_to"/>
        <field name="body_html" type="html">
            <p>Xin chào Bộ phận Sales,</p>
            <p>Chúng tôi đã tìm thấy lô hàng sau đây sẽ hết hạn trong 10 ngày tới. Vui lòng ưu tiên xử lý:</p>
            <table style="width:100%; border-collapse: collapse;">
                <thead>
                    <tr style="background-color: #f2f2f2;">
                        <th style="border: 1px solid #ddd; padding: 8px;">Sản phẩm</th>
                        <th style="border: 1px solid #ddd; padding: 8px;">Mã Lô</th>
                        <th style="border: 1px solid #ddd; padding: 8px;">Số Lượng Tồn Kho</th>
                        <th style="border: 1px solid #ddd; padding: 8px;">Ngày Hết hạn</th>
                        <th style="border: 1px solid #ddd; padding: 8px;">Ngày Còn Lại</th>
                    </tr>
                </thead>
                <tbody>
                    <t t-foreach="ctx.get('expiring_products', [])" t-as="lot">
                        <tr>
                            <td style="border: 1px solid #ddd; padding: 8px;">
                                <span t-esc="lot.product_id.display_name"/>
                            </td>
                            <td style="border: 1px solid #ddd; padding: 8px;">
                                <span t-esc="lot.name"/>
                            </td>
                            <td style="border: 1px solid #ddd; padding: 8px;">
                                <span t-esc="lot.product_qty"/>
                            </td>
                            <td style="border: 1px solid #ddd; padding: 8px;">
                                <span t-esc="lot.expiration_date"/>
                            </td>
                            <td style="border: 1px solid #ddd; padding: 8px;">
                                <span t-esc="lot.days_to_expire"/>
                            </td>
                        </tr>
                    </t>
                </tbody>
            </table>
            <p>Trân trọng,</p>
        </field>
    </record>
</odoo>